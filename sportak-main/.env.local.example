# ─── Slack OAuth ──────────────────────────────────────────────────────────────
# Create a Slack App at https://api.slack.com/apps
# OAuth scopes required: openid, email, profile
# Redirect URL: https://<your-domain>/api/auth/callback/slack

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Restrict login to a single Slack workspace (recommended).
# Find your Team ID in Slack → Settings → Workspace settings → scroll to bottom.
SLACK_TEAM_ID=

# ─── Admin bootstrap ──────────────────────────────────────────────────────────
# Comma-separated Slack User IDs that receive the admin role on first login.
# After first login the role lives in the DB — this env var is no longer needed.
# Find a user's Slack ID: click their profile → ⋮ → Copy member ID
ADMIN_SLACK_IDS=U0123456789,U0987654321

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development — uses a local SQLite file, no auth token needed
TURSO_DATABASE_URL=file:./dev.db
TURSO_AUTH_TOKEN=

# Production (Turso cloud) — replace with values from `turso db show <db-name>`
# TURSO_DATABASE_URL=libsql://<db-name>-<org>.turso.io
# TURSO_AUTH_TOKEN=eyJ...

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Slack notifications (bot) ────────────────────────────────────────────────
# Bot User OAuth Token (xoxb-...) from Slack App → OAuth & Permissions.
# Required scope: chat:write
# May be left blank in local dev — notifications then log a "missing_token"
# warning and the activity write still succeeds.
SLACK_BOT_TOKEN=

# Channel for broadcast notifications (bonus announcements, weekly summaries).
# Find via Slack channel details → bottom of panel → "Copy channel ID" (C...).
# In dev you can paste your own user ID (U...) here — Slack opens a DM, message
# arrives to you privately. Bot must be a member of the target channel.
SLACK_CHANNEL_ID=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Shared secret between Vercel cron jobs and our /api/cron/* endpoints.
# Generate with: openssl rand -base64 32
# Set the same value in Vercel project settings → Environment Variables.
CRON_SECRET=
